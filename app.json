{
  "expo": {
    "name": "Happ-E",
    "slug": "happ-e",
    "version": "1.0.0",
    "orientation": "default",
    "icon": "./assets/images/App_Icon.png",
    "scheme": "happyapp",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
  "supportsTablet": true,
  "bundleIdentifier": "com.seaolivestudios.happe",
  "infoPlist": {
    "ITSAppUsesNonExemptEncryption": false,
    "NSPhotoLibraryUsageDescription": "Happ-E needs access to your photos so you can share your creativity.",
    "NSCameraUsageDescription": "Happ-E needs access to your camera so you can capture and share moments.",
    "NSMicrophoneUsageDescription": "Happ-E needs microphone access for video recording."
  }
},
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/App_Icon.png",
        "backgroundColor": "#000000"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/App_Icon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/Logo v_1.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#000000"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "1505094b-19d4-42b2-98a1-35eda829c077"
      }
    }
  }
}
